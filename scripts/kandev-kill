#!/usr/bin/env bash
# kandev-kill — terminate exactly ONE kandev instance: the backend listening on
# a given port, plus its agentctl child(ren) and its matching web/next server.
#
# This NEVER does a blanket `pkill kandev`. It resolves the backend PID from the
# port, confirms the process is actually a kandev backend, computes the exact
# set of PIDs it will signal, PRINTS that set, and only then (after confirmation)
# sends SIGTERM, escalating to SIGKILL after a short grace period.
#
# Safety:
#   - Refuses to act unless you explicitly pass a port or a --pidfile.
#   - The well-known production port 38429 is GUARDED: killing it requires an
#     explicit --force. (This is the port the user's live instance uses.)
#   - Prints exactly what will be killed and asks for confirmation, unless --yes
#     is given (for scripted teardown).
#
# Usage:
#   scripts/kandev-kill <backend_port> [--yes] [--force]
#   scripts/kandev-kill --pidfile /tmp/kandev-dev-isolated-<port>.pid [--yes]
#
# Examples:
#   scripts/kandev-kill 48429 --yes
#   scripts/kandev-kill --pidfile /tmp/kandev-dev-isolated-48429.pid --yes
#
set -euo pipefail

GUARDED_PORT=38429
GRACE_SECONDS=5

PORT=""
PIDFILE=""
ASSUME_YES=0
FORCE=0

usage() {
  sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-2}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pidfile)
      PIDFILE="${2:?--pidfile requires a path}"
      shift 2
      ;;
    --yes|-y)
      ASSUME_YES=1
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    -h|--help)
      usage 0
      ;;
    --*)
      echo "kandev-kill: unknown flag '$1'" >&2
      usage 2
      ;;
    *)
      if [[ -z "$PORT" ]]; then
        PORT="$1"
      else
        echo "kandev-kill: unexpected argument '$1'" >&2
        usage 2
      fi
      shift
      ;;
  esac
done

# Resolve the backend PID listening on a TCP port.
pid_for_port() {
  local port="$1" pid=""
  if command -v ss >/dev/null 2>&1; then
    pid="$(ss -tlnpH "sport = :$port" 2>/dev/null |
      grep -oE 'pid=[0-9]+' | head -1 | cut -d= -f2)"
  fi
  if [[ -z "$pid" ]] && command -v lsof >/dev/null 2>&1; then
    pid="$(lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null | head -1)"
  fi
  printf '%s\n' "$pid"
}

# Confirm a PID is a kandev backend (exe basename or cmdline mentions kandev).
is_kandev_backend() {
  local pid="$1" exe cmd
  [[ -d "/proc/$pid" ]] || return 1
  exe="$(readlink "/proc/$pid/exe" 2>/dev/null || true)"
  [[ "$(basename "$exe" 2>/dev/null)" == "kandev" ]] && return 0
  cmd="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null || true)"
  case "$cmd" in
    */kandev*|*bin/kandev*) return 0 ;;
  esac
  return 1
}

# --- Resolve the target backend PID + port ---
BACKEND_PID=""
if [[ -n "$PIDFILE" ]]; then
  [[ -f "$PIDFILE" ]] || { echo "kandev-kill: pidfile not found: $PIDFILE" >&2; exit 1; }
  BACKEND_PID="$(tr -d '[:space:]' <"$PIDFILE")"
  [[ "$BACKEND_PID" =~ ^[0-9]+$ ]] || { echo "kandev-kill: pidfile has no numeric PID: $PIDFILE" >&2; exit 1; }
  if [[ ! -d "/proc/$BACKEND_PID" ]]; then
    echo "kandev-kill: process $BACKEND_PID from pidfile is already gone; nothing to do." >&2
    rm -f "$PIDFILE" 2>/dev/null || true
    exit 0
  fi
  # Derive the listening port from the running process for guard checks/output.
  if command -v ss >/dev/null 2>&1; then
    PORT="$(ss -tlnpH 2>/dev/null | grep "pid=$BACKEND_PID," | grep -oE ':[0-9]+ ' | tr -d ': ' | sort -n | head -1)"
  fi
elif [[ -n "$PORT" ]]; then
  [[ "$PORT" =~ ^[0-9]+$ ]] || { echo "kandev-kill: port must be numeric, got '$PORT'" >&2; exit 2; }
  BACKEND_PID="$(pid_for_port "$PORT")"
  [[ -n "$BACKEND_PID" ]] || { echo "kandev-kill: no listening process found on port $PORT" >&2; exit 1; }
else
  echo "kandev-kill: refusing to run without an explicit <port> or --pidfile." >&2
  usage 2
fi

# --- Safety guards ---
if [[ "${PORT:-}" == "$GUARDED_PORT" && "$FORCE" -ne 1 ]]; then
  echo "kandev-kill: port $GUARDED_PORT is the guarded production port (the user's live instance)." >&2
  echo "             Refusing to kill it without --force." >&2
  exit 3
fi

if ! is_kandev_backend "$BACKEND_PID"; then
  echo "kandev-kill: PID $BACKEND_PID (port ${PORT:-?}) does not look like a kandev backend. Aborting." >&2
  exit 4
fi

# --- Compute the kill set: backend + descendants (agentctl + web if children) ---
# Collect the full descendant tree of the backend PID.
collect_descendants() {
  local root="$1"
  local -a queue=("$root")
  local -a out=()
  while [[ ${#queue[@]} -gt 0 ]]; do
    local cur="${queue[0]}"
    queue=("${queue[@]:1}")
    out+=("$cur")
    local kids
    kids="$(pgrep -P "$cur" 2>/dev/null || true)"
    for k in $kids; do
      queue+=("$k")
    done
  done
  printf '%s\n' "${out[@]}"
}

mapfile -t TREE < <(collect_descendants "$BACKEND_PID")

# The web/next server is typically a sibling (spawned by the launcher, not a
# child of the backend). If a pidfile sidecar lists it, include it.
WEB_PID=""
if [[ -n "$PIDFILE" && -f "${PIDFILE%.pid}.web.pid" ]]; then
  WEB_PID="$(tr -d '[:space:]' <"${PIDFILE%.pid}.web.pid" 2>/dev/null || true)"
  if [[ "$WEB_PID" =~ ^[0-9]+$ && -d "/proc/$WEB_PID" ]]; then
    TREE+=("$WEB_PID")
  else
    WEB_PID=""
  fi
fi

# Describe the kill set.
echo "kandev-kill: will terminate the following processes (backend port ${PORT:-?}):"
for p in "${TREE[@]}"; do
  cmd="$( (tr '\0' ' ' <"/proc/$p/cmdline") 2>/dev/null | cut -c1-90 || true)"
  echo "  PID $p  ${cmd:-<gone>}"
done

if [[ "$ASSUME_YES" -ne 1 ]]; then
  printf 'Proceed? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) echo "kandev-kill: aborted by user."; exit 0 ;;
  esac
fi

# --- Terminate: SIGTERM the process group first (cascades to agent children),
# then any stragglers individually, then SIGKILL after the grace period. ---
signal_tree() {
  local sig="$1"
  # Signal the backend's process group (negative PID) so detached children
  # cascade. Then signal each known PID individually as a fallback.
  kill -"$sig" -- -"$BACKEND_PID" 2>/dev/null || true
  for p in "${TREE[@]}"; do
    kill -"$sig" "$p" 2>/dev/null || true
  done
}

signal_tree TERM

# Wait up to GRACE_SECONDS for the backend to exit.
waited=0
while [[ -d "/proc/$BACKEND_PID" && "$waited" -lt "$GRACE_SECONDS" ]]; do
  sleep 1
  waited=$((waited + 1))
done

if [[ -d "/proc/$BACKEND_PID" ]]; then
  echo "kandev-kill: backend still alive after ${GRACE_SECONDS}s, sending SIGKILL."
  signal_tree KILL
  sleep 1
fi

# Reap any remaining tracked PIDs with SIGKILL.
for p in "${TREE[@]}"; do
  if [[ -d "/proc/$p" ]]; then
    kill -KILL "$p" 2>/dev/null || true
  fi
done

if [[ -d "/proc/$BACKEND_PID" ]]; then
  echo "kandev-kill: WARNING — backend PID $BACKEND_PID is still present." >&2
  exit 5
fi

# Clean up pidfile(s).
if [[ -n "$PIDFILE" ]]; then
  rm -f "$PIDFILE" "${PIDFILE%.pid}.web.pid" 2>/dev/null || true
fi

echo "kandev-kill: done. Backend on port ${PORT:-?} (PID $BACKEND_PID) terminated."
